      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "(sum(rate(http_server_request_duration_seconds_count{service_name=\"$service_name\"}[$__rate_interval])) by (deployment_environment_name, service_namespace, service_name)) ",
          "instant": false,
          "interval": "60s",
          "legendFormat": "HTTP requests",
          "range": true,
          "refId": "HTTP RPS"
        }
      ],
      "title": "Request Rate",
