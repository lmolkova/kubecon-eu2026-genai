      },
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 15,
        "y": 3
      },
      "id": 40,
      "options": {
        "alertInstanceLabelFilter": "{service_name=\"$service_name\"}",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
